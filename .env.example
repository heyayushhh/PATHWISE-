# PathWise Environment Variables
# Copy this file to .env and fill in the values

# Node
NODE_ENV=development
PORT=3001

# PostgreSQL
POSTGRES_USER=pathwise
POSTGRES_PASSWORD=pathwise123
POSTGRES_DB=pathwise
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://pathwise:pathwise123@localhost:5432/pathwise?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pathwise123

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AI_ENGINE_URL=http://127.0.0.1:3002

# Google OAuth
# MS1 Core API — server-side ID token verification
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Frontend — passed at Next.js build time and runtime
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# LLM Provider (OpenAI/Gemini)
OPENAI_API_KEY=
GEMINI_API_KEY=
